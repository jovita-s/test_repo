{
  "version": 8,
  "name": "map_topo",
  "metadata": {"maputnik:renderer": "mbgljs"},
  "sources": {
    "tilezen": {
      "type": "vector",
      "url": "https://openmap.lt/capabilities/all.json"
    },
    "detail": {
      "type": "vector",
      "url": "https://openmap.lt/capabilities/detail.json"
    }
  },
  "sprite": "https://openmap.lt/sprites/openmaplt",
  "glyphs": "https://openmap.lt/glyphs/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "boundary-country",
      "type": "line",
      "source": "tilezen",
      "source-layer": "boundaries",
      "minzoom": 15,
      "maxzoom": 20,
      "filter": ["all", ["==", "kind", "country"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "line-miter-limit": 2,
        "line-round-limit": 1.1,
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(232, 176, 113, 1)",
        "line-width": {"stops": [[7, 2], [16, 14]]},
        "line-translate-anchor": "map",
        "line-offset": {"stops": [[7, 1], [16, -7]]}
      }
    },
    {
      "id": "buildings-ruins",
      "type": "line",
      "source": "tilezen",
      "source-layer": "buildings",
      "minzoom": 13,
      "maxzoom": 20,
      "filter": ["all", ["==", "kind", "ruins"]],
      "layout": {"visibility": "visible"},
      "paint": {
        "line-color": {
          "stops": [[13, "rgba(221, 221, 221, 1)"], [20, "#888888"]]
        },
        "line-width": {"stops": [[14, 0.5], [16, 2]]}
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "tilezen",
      "source-layer": "buildings",
      "minzoom": 13,
      "maxzoom": 20,
      "filter": ["all", ["!=", "kind", "ruins"]],
      "layout": {"visibility": "visible"},
      "paint": {
        "fill-outline-color": {
          "stops": [[14, "rgba(204, 204, 204, 1)"], [20, "#333333"]]
        },
        "fill-color": {
          "stops": [[13, "rgba(150, 131, 121, 1)"], [20, "rgba(78, 63, 53, 1)"]]
        }
      }
    },
    {
      "id": "road-service",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "filter": ["all", ["in", "kind", "service"]],
      "layout": {
        "line-join": "round",
        "line-cap": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(156, 141, 141, 1)",
        "line-width": {"base": 1.55, "stops": [[8, 1], [20, 9]]}
      }
    },
    {
      "id": "road-road-small",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "minzoom": 8,
      "maxzoom": 13,
      "filter": [
        "any",
        ["in", "kind", "residential", "unclassified", "living_street"]
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(170, 170, 170, 1)",
        "line-width": {"base": 1.55, "stops": [[4, 0.25], [20, 30]]}
      }
    },
    {
      "id": "road-road",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "minzoom": 13,
      "filter": [
        "any",
        [
          "in",
          "kind",
          "residential",
          "unclassified",
          "living_street",
          "pedestrian"
        ]
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(227, 224, 213, 1)",
        "line-width": {"base": 1.55, "stops": [[4, 0.25], [20, 30]]}
      }
    },
    {
      "id": "road-tertiary",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "filter": ["all", ["in", "kind", "tertiary", "tertiary_link"]],
      "layout": {
        "line-join": "round",
        "line-cap": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(229, 192, 163, 1)",
        "line-width": {"base": 1.55, "stops": [[5, 0.5], [20, 20]]}
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "filter": ["all", ["in", "kind", "secondary", "secondary_link"]],
      "layout": {
        "line-join": "round",
        "line-cap": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(249, 190, 125, 1)",
        "line-width": {"base": 1.55, "stops": [[5, 0.5], [20, 20]]}
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "filter": ["all", ["in", "kind", "primary", "primary_link"]],
      "layout": {
        "line-join": "round",
        "line-cap": "butt",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(225, 177, 124, 1)",
        "line-width": {"base": 1.55, "stops": [[5, 0.5], [20, 34]]}
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "filter": [
        "all",
        ["in", "kind", "motorway", "motorway_link", "trunk", "trunk_link"]
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(225, 150, 55, 1)",
        "line-width": {"base": 1.55, "stops": [[5, 0.5], [20, 34]]}
      }
    },
    {
      "id": "road-proposed",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "minzoom": 12,
      "maxzoom": 24,
      "filter": ["all", ["in", "kind", "proposed", "construction"]],
      "layout": {
        "line-join": "round",
        "line-cap": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(191, 191, 191, 1)",
        "line-width": {"base": 1.8, "stops": [[10, 5], [20, 15]]},
        "line-dasharray": [0.3, 2],
        "line-opacity": 0.5
      }
    },
    {
      "id": "road-oneway",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "minzoom": 16,
      "maxzoom": 24,
      "filter": [
        "all",
        [
          "in",
          "kind",
          "residential",
          "unclassified",
          "living_street",
          "service",
          "tertiary",
          "tertiary_link",
          "secondary",
          "secondary_link",
          "primary",
          "primary_link",
          "trunk",
          "trunk_link",
          "motorway",
          "motorway_link"
        ],
        ["==", "oneway", "yes"]
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-width": {"base": 1.55, "stops": [[4, 0.25], [20, 30]]},
        "line-pattern": "oneway",
        "line-opacity": 0.6
      }
    },
    {
      "id": "road-track",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "minzoom": 12,
      "maxzoom": 24,
      "filter": ["all", ["in", "kind", "track"]],
      "layout": {
        "line-join": "round",
        "line-cap": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(136, 122, 102, 1)",
        "line-width": {"base": 1.8, "stops": [[10, 0.15], [20, 15]]},
        "line-dasharray": [2, 4]
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "tilezen",
      "source-layer": "roads",
      "minzoom": 12,
      "maxzoom": 24,
      "filter": ["all", ["in", "kind", "path", "footway", "steps", "cycleway"]],
      "layout": {
        "line-join": "round",
        "line-cap": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "rgba(76, 34, 17, 1)",
        "line-width": {"base": 1.8, "stops": [[10, 0.5], [20, 3]]},
        "line-dasharray": [2, 5]
      }
    },
    {
      "id": "road-hiking",
      "type": "line",
      "source": "tilezen",
      "source-layer": "routes",
      "minzoom": 14,
      "maxzoom": 24,
      "filter": ["all"],
      "layout": {
        "line-join": "bevel",
        "line-cap": "round",
        "visibility": "visible",
        "line-miter-limit": 2
      },
      "paint": {"line-color": "rgba(122, 18, 49, 0.3)", "line-width": 8}
    }
  ],
  "id": "asgr00hhi",
  "owner": ""
}
